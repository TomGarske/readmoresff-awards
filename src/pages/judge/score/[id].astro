---
import Base from "../../../layouts/Base.astro";
import { getCurrentUser } from "../../../lib/auth";
import { adminSupabase } from "../../../lib/supabase";
import { lookupGenre, lookupTheme, lookupObject } from "../../../lib/prompts";
import { getSignedDownloadUrl } from "../../../lib/r2-upload";

const user = await getCurrentUser(Astro.cookies);
if (!user) return Astro.redirect("/login?next=/judge", 303);

const assignmentId = Astro.params.id;
const sb = adminSupabase();

// Confirm this assignment belongs to this judge
const { data: judgeRow } = await sb
  .from("judges").select("id").eq("user_id", user.id).maybeSingle();
if (!judgeRow) return Astro.redirect("/judge", 303);

const { data: assignment } = await sb
  .from("assignments")
  .select(`
    id, status,
    submissions(id, title, synopsis, word_count, anonymized_r2_key,
      groups:group_members(group_id, groups(number, prompt_genre, prompt_theme, prompt_object))
    ),
    scores(id, prompt_adherence, originality, prose, structure, total, feedback_md, submitted_at)
  `)
  .eq("id", assignmentId)
  .eq("judge_id", judgeRow.id)
  .maybeSingle();

if (!assignment) return Astro.redirect("/judge", 303);

const s = assignment.submissions;
const grp = s?.groups?.[0]?.groups;
const g = grp ? lookupGenre(grp.prompt_genre)?.name : "—";
const t = grp ? lookupTheme(grp.prompt_theme)?.name : "—";
const o = grp ? lookupObject(grp.prompt_object)?.name : "—";

// Generate a 1-hour signed URL for the anonymized file
let downloadUrl: string | null = null;
if (s?.anonymized_r2_key) {
  try {
    downloadUrl = await getSignedDownloadUrl(s.anonymized_r2_key, 60 * 60);
  } catch (e) {
    console.warn("Could not sign URL", e);
  }
}

const score = assignment.scores?.[0] ?? null;
---
<Base title="Score submission">
  <div class="narrow">
    <div class="section-head" style="margin-bottom:14px;">
      <h2>{s?.title ?? "Untitled"}</h2>
      <p class="sub">Group {grp?.number ?? "?"} · {g} · {t} · {o} · {s?.word_count ?? "?"} words</p>
    </div>

    <div class="card" style="margin-bottom:18px;">
      <h3 style="margin-top:0;">Synopsis</h3>
      <p style="color:var(--ink-dim);font-style:italic;margin:0;">{s?.synopsis ?? "—"}</p>
    </div>

    {downloadUrl ? (
      <p><a class="btn primary" href={downloadUrl} target="_blank" rel="noopener">Download anonymized story (.docx)</a></p>
    ) : (
      <div class="callout bad">Story file not yet available.</div>
    )}

    <form method="POST" action="/api/judge/score" class="card" style="padding:22px;margin-top:18px;">
      <input type="hidden" name="assignment_id" value={assignment.id} />

      <h3 style="margin-top:0;">Rubric · 4 dimensions · 25 points each · 100 total</h3>

      <div class="form-row">
        <label for="prompt_adherence">Prompt adherence (1–25)</label>
        <input type="number" id="prompt_adherence" name="prompt_adherence" min="1" max="25" required value={score?.prompt_adherence ?? ""} />
        <div class="hint">Does the story unmistakably fit the assigned genre, hinge on the theme, and physically include the object?</div>
      </div>
      <div class="form-row">
        <label for="originality">Originality (1–25)</label>
        <input type="number" id="originality" name="originality" min="1" max="25" required value={score?.originality ?? ""} />
        <div class="hint">Voice, premise, execution. Does the story feel like only this writer could have written it?</div>
      </div>
      <div class="form-row">
        <label for="prose">Prose (1–25)</label>
        <input type="number" id="prose" name="prose" min="1" max="25" required value={score?.prose ?? ""} />
        <div class="hint">Sentence-level craft. Clarity, rhythm, image precision.</div>
      </div>
      <div class="form-row">
        <label for="structure">Structure (1–25)</label>
        <input type="number" id="structure" name="structure" min="1" max="25" required value={score?.structure ?? ""} />
        <div class="hint">Story arc within 1,500 words. Setup, escalation, resolution.</div>
      </div>
      <div class="form-row">
        <label for="feedback_md">Feedback (markdown allowed)</label>
        <textarea id="feedback_md" name="feedback_md" rows="8" placeholder="100–300 words. Specific praise, specific cuts. The writer will read this verbatim.">{score?.feedback_md ?? ""}</textarea>
      </div>

      <div style="display:flex;gap:10px;">
        <button type="submit" name="action" value="save_draft" class="btn">Save draft</button>
        <button type="submit" name="action" value="submit_final" class="btn primary">Submit final score</button>
        <a href="/judge" class="btn ghost">← Back</a>
      </div>
      {score?.submitted_at && (
        <p class="hint" style="margin-top:10px;color:var(--good);">
          Last submitted {new Date(score.submitted_at).toLocaleString()}. Re-submitting overwrites.
        </p>
      )}
    </form>
  </div>
</Base>
