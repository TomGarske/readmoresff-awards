---
import Base from "../layouts/Base.astro";
---
<Base title="Sign in">
  <div class="narrow">
    <div class="section-head" style="margin-bottom:18px;">
      <h2>Sign in</h2>
      <p class="sub">We'll email you a magic link. No password required.</p>
    </div>
    <form method="POST" action="/api/auth/send-link" class="card" style="padding:22px;">
      <div class="form-row">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autocomplete="email" placeholder="you@example.com" />
      </div>
      <button type="submit" class="btn primary" style="width:100%;">Send magic link</button>
    </form>
  </div>
</Base>
