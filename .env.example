# ====== ReadMoreSFF Awards · environment ======
# Copy to .env (which is gitignored) and fill in real values.

# --- Supabase (auth + Postgres) ---
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # server-only; never expose to client

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Prices in cents. List $45 / promo $35.
STRIPE_PRICE_LIST_CENTS=4500
STRIPE_PRICE_PROMO_CENTS=3500
STRIPE_PROMO_CODE=READMORE10

# --- Cloudflare R2 (file storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_SUBMISSIONS=readmoresff-submissions
R2_BUCKET_ANONYMIZED=readmoresff-anonymized

# --- Resend (email) ---
RESEND_API_KEY=re_...
EMAIL_FROM="ReadMoreSFF Awards <awards@readmoresff.org>"

# --- App config ---
SITE_URL=https://readmoresff.org
ADMIN_EMAILS=tdgarske@gmail.com
# Inaugural challenge ID (creates one in the challenges table)
CURRENT_CHALLENGE_SLUG=readmoresff-1500-2026
